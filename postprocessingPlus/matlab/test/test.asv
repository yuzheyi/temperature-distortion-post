% 设置循环次数
numIterations = 100; % 循环迭代次数
results = zeros(1, numIterations);

% 创建进度条的标志
hWaitbar = waitbar(0, 'Processing...');

% 使用 parfor 循环
parfor i = 1:numIterations
    % 模拟处理
    pause(0.1); % 模拟一些计算时间
    results(i) = i; % 示例计算结果
end

% 更新进度条（在主工作者中）
for i = 1:numIterations
    waitbar(i / numIterations, hWaitbar, sprintf('Processing... %d%%', round(i / numIterations * 100)));
end

% 关闭进度条
close(hWaitbar);

% 显示结果
disp('Processing complete!');


